<!DOCTYPE html>
<html>
<head>
    <title>Space Invaders - VS Games</title>
    <style>
        body { background: #000; color: #fff; text-align: center; font-family: sans-serif; }
        canvas { border: 2px solid #58a6ff; background: #000; }
    </style>
</head>
<body>
    <h1>SPACE INVADERS</h1>
    <canvas id="gameCanvas" width="400" height="400"></canvas>
    <script>
        const canvas = document.getElementById('gameCanvas');
        const ctx = canvas.getContext('2d');
        let player = { x: 180, y: 370, w: 40, h: 20 };
        function draw() {
            ctx.clearRect(0, 0, 400, 400);
            ctx.fillStyle = '#0f0'; // Cor do player
            ctx.fillRect(player.x, player.y, player.w, player.h);
            requestAnimationFrame(draw);
        }
        window.addEventListener('keydown', e => {
            if(e.key === 'ArrowLeft' && player.x > 0) player.x -= 15;
            if(e.key === 'ArrowRight' && player.x < 360) player.x += 15;
        });
        draw();
    </script>
</body>
</html>
