<!doctype html>
<html lang="pt-BR" class="h-full">
 <head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Valoranto</title>
  <script src="https://cdn.tailwindcss.com/3.4.17"></script>
  <script src="https://cdn.jsdelivr.net/npm/lucide@0.263.0/dist/umd/lucide.min.js"></script>
  <script src="/_sdk/element_sdk.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&amp;family=Orbitron:wght@400;700;900&amp;display=swap" rel="stylesheet">
  <style>
    * { box-sizing: border-box; }

    @keyframes flipIn {
      0% { transform: rotateX(90deg); opacity: 0; }
      100% { transform: rotateX(0deg); opacity: 1; }
    }
    @keyframes shake {
      0%, 100% { transform: translateX(0); }
      20%, 60% { transform: translateX(-6px); }
      40%, 80% { transform: translateX(6px); }
    }
    @keyframes popIn {
      0% { transform: scale(0.8); opacity: 0; }
      50% { transform: scale(1.1); }
      100% { transform: scale(1); opacity: 1; }
    }
    @keyframes bounceIn {
      0% { transform: scale(0.3); opacity: 0; }
      50% { transform: scale(1.05); }
      70% { transform: scale(0.95); }
      100% { transform: scale(1); opacity: 1; }
    }
    @keyframes slideDown {
      0% { transform: translateY(-20px); opacity: 0; }
      100% { transform: translateY(0); opacity: 1; }
    }
    @keyframes glow {
      0%, 100% { box-shadow: 0 0 10px rgba(255, 70, 85, 0.5); }
      50% { box-shadow: 0 0 20px rgba(255, 70, 85, 0.8); }
    }
    @keyframes confetti {
      0% { transform: translateY(0) rotate(0deg); opacity: 1; }
      100% { transform: translateY(100px) rotate(360deg); opacity: 0; }
    }
    @keyframes victoryScale {
      0% { transform: scale(1); }
      25% { transform: scale(1.1); }
      50% { transform: scale(1.05); }
      75% { transform: scale(1.08); }
      100% { transform: scale(1); }
    }
    @keyframes victoryGlow {
      0%, 100% { filter: drop-shadow(0 0 8px rgba(255, 70, 85, 0.5)); }
      50% { filter: drop-shadow(0 0 20px rgba(255, 70, 85, 1)); }
    }
    .flip-in { animation: flipIn 0.4s ease forwards; }
    .shake { animation: shake 0.5s ease; }
    .pop-in { animation: popIn 0.2s ease forwards; }
    .bounce-in { animation: bounceIn 0.6s ease forwards; }
    .slide-down { animation: slideDown 0.4s ease forwards; }
    .glow { animation: glow 1s ease-in-out; }
    .confetti-piece { animation: confetti 1s ease-out forwards; }
    .victory-pulse { animation: victoryScale 0.6s ease-out, victoryGlow 1.2s ease-in-out infinite; }

    .cell {
      width: 56px; height: 56px;
      border: 2px solid #333;
      display: flex; align-items: center; justify-content: center;
      font-family: 'Orbitron', monospace;
      font-weight: 700; font-size: 1.4rem;
      text-transform: uppercase;
      transition: border-color 0.2s;
      color: #fff;
    }
    .cell.active { border-color: #ff4655; }
    .cell.correct { background: #538d4e; border-color: #538d4e; }
    .cell.present { background: #b59f3b; border-color: #b59f3b; }
    .cell.absent { background: #3a3a3c; border-color: #3a3a3c; }

    .key {
      height: 52px; min-width: 32px; padding: 0 8px;
      border-radius: 6px; border: none;
      font-family: 'Rajdhani', sans-serif;
      font-weight: 600; font-size: 0.85rem;
      cursor: pointer; text-transform: uppercase;
      transition: all 0.15s;
      color: #fff; background: #555;
    }
    .key:hover { filter: brightness(1.2); }
    .key:active { transform: scale(0.95); }
    .key.correct { background: #538d4e; }
    .key.present { background: #b59f3b; }
    .key.absent { background: #2a2a2c; color: #666; }
    .key.wide { min-width: 56px; font-size: 0.75rem; }

    .toast-msg {
      position: fixed; top: 80px; left: 50%; transform: translateX(-50%);
      padding: 10px 24px; border-radius: 8px; z-index: 100;
      font-family: 'Rajdhani', sans-serif; font-weight: 600; font-size: 1rem;
      color: #fff; pointer-events: none;
      animation: popIn 0.3s ease forwards;
    }

    .modal-overlay {
      position: fixed; inset: 0; background: rgba(0,0,0,0.7);
      display: flex; align-items: center; justify-content: center; z-index: 200;
    }
  </style>
  <style>body { box-sizing: border-box; }</style>
  <script src="/_sdk/data_sdk.js" type="text/javascript"></script>
 </head>
 <body class="h-full">
  <div id="app" class="h-full w-full overflow-auto flex flex-col items-center" style="background: linear-gradient(135deg, #0f1923 0%, #1a0a0a 50%, #0f1923 100%); font-family: 'Rajdhani', sans-serif;">
   <!-- Header -->
   <header class="w-full flex items-center justify-between px-4 py-4 relative" style="border-bottom: 2px solid #ff465540;">
    <div class="absolute left-0 right-0 h-px bottom-0" style="background: linear-gradient(90deg, transparent, #ff4655, transparent);"></div>
    <div class="flex-1 text-center">
     <h1 id="title" class="text-3xl md:text-4xl font-black tracking-widest" style="font-family: 'Orbitron', monospace; color: #ff4655;">VALORANT</h1>
    </div>
    <div class="flex gap-4 text-sm font-bold" style="color: #888;">
     <div class="flex flex-col items-center"><span style="color: #ff4655; font-size: 1.2rem;" id="win-count">0</span> <span>Vitórias</span>
     </div>
     <div class="flex flex-col items-center"><span style="color: #888; font-size: 1.2rem;" id="loss-count">0</span> <span>Derrotas</span>
     </div>
    </div>
   </header><!-- Toast container -->
   <div id="toast-container"></div><!-- Grid -->
   <main class="flex flex-col items-center gap-1.5 mt-4 px-2" id="grid"></main><!-- Keyboard -->
   <div class="mt-auto pb-4 pt-4 px-1 w-full max-w-lg flex flex-col items-center gap-1.5" id="keyboard"></div><!-- Modal -->
   <div id="modal" class="modal-overlay" style="display:none;">
    <div class="bounce-in rounded-xl p-6 text-center max-w-sm w-full mx-4" style="background: #1a1a2e; border: 2px solid #ff4655;">
     <div id="modal-icon" class="text-5xl mb-3"></div>
     <h2 id="modal-title" class="text-2xl font-bold mb-1" style="font-family: 'Orbitron', monospace; color: #ff4655;"></h2>
     <p id="modal-word" class="text-lg mb-1 text-gray-300"></p>
     <p id="modal-desc" class="text-sm text-gray-400 mb-4"></p><button id="modal-btn" class="px-6 py-2.5 rounded-lg font-bold text-white transition hover:brightness-110" style="background: #ff4655; font-family: 'Orbitron', monospace;" onclick="newGame()">JOGAR DE NOVO</button>
    </div>
   </div>
  </div>
  <script>
  // === WORD LIST (5-letter Valorant terms) ===
  const WORDS = [
    // AGENTES (5 letras)
    {w:'JETT',d:'Agente duelista coreana'},
    {w:'RAZE',d:'Agente duelista brasileira'},
    {w:'SAGE',d:'Agente sentinela chinesa'},
    {w:'SOVA',d:'Agente iniciador russo'},
    {w:'OMEN',d:'Agente controlador misterioso'},
    {w:'YORU',d:'Agente duelista japonês'},
    {w:'NEON',d:'Agente duelista filipina'},
    {w:'FADE',d:'Agente iniciadora turca'},
    {w:'KAYO',d:'Agente iniciador robô'},
    {w:'VYSE',d:'Agente sentinela'},
    
    // MAPAS (5 letras)
    {w:'SPLIT',d:'Mapa com elevadores'},
    {w:'PEARL',d:'Mapa subaquático'},
    {w:'LOTUS',d:'Mapa com portas giratórias'},
    {w:'ABYSS',d:'Mapa sem barreiras'},
    
    // ARMAS (5 letras)
    {w:'GHOST',d:'Pistola silenciosa'},
    {w:'JUDGE',d:'Escopeta automática'},
    {w:'ODIN',d:'Metralhadora pesada'},
    
    // TERMOS DE JOGO (5 letras)
    {w:'SPIKE',d:'Bomba para plantar'},
    {w:'PLANT',d:'Ação de plantar spike'},
    {w:'FLASH',d:'Habilidade que cega'},
    {w:'SMOKE',d:'Cortina de fumaça'},
    {w:'TRADE',d:'Abate em troca'},
    {w:'LURK',d:'Jogar sozinho no mapa'},
    {w:'ENTRY',d:'Primeiro a entrar no site'},
    {w:'MOLLY',d:'Habilidade de fogo'},
    {w:'ARMOR',d:'Colete de proteção'},
    {w:'ROUND',d:'Uma rodada da partida'},
    {w:'PATCH',d:'Atualização do jogo'},
    {w:'NERF',d:'Enfraquecimento'},
    {w:'AGENT',d:'Personagem jogável'},
    {w:'PRIME',d:'Skin popular'},
    {w:'FAULT',d:'Falha sísmica Breach'},
    {w:'SURGE',d:'Onda de Harbor'},
    
    // HABILIDADES ESPECÍFICAS (5 letras)
    {w:'BLADE',d:'Lâmina de Jett'},
    {w:'DRONE',d:'Drone de Sova'},
    {w:'CHARM',d:'Charm de Reyna'},
    {w:'STASIS',d:'Stasis de Sage'}, // 6 letras
    {w:'REBAR',d:'Barra armada Cypher'}, // 5 letras - skip
    {w:'DECOY',d:'Boneco de Yoru'},
    {w:'WINK',d:'Teletransporte Yoru'}, // 4 letras - skip
    {w:'SPARK',d:'Faísca de energia'},
    {w:'DECAY',d:'Decaimento de tempo'},
    {w:'PROWL',d:'Espreitar inimigo'},
    
    // STATS E GAMEPLAY (5 letras)
    {w:'FRAG',d:'Eliminação inimiga'}, // 4 letras - skip
    {w:'DUELIST',d:'Tipo de agente'}, // 7 letras - skip
    {w:'DUEL',d:'Combate 1v1'}, // 4 letras - skip
    {w:'COVER',d:'Cobertura tática'},
    {w:'PEEKER',d:'Jogador agressivo'}, // 6 letras - skip
    {w:'PUSH',d:'Avançar posição'}, // 4 letras - skip
    {w:'HOLD',d:'Manter posição'}, // 4 letras - skip
    {w:'SPAWN',d:'Ponto de início'},
    {w:'SETUP',d:'Preparação antes rodada'}, // 5 letras!
    {w:'WASTE',d:'Gastar habilidade'},
    {w:'RESET',d:'Reiniciar rodada'},
    {w:'STACK',d:'Agrupar equipe'},
    {w:'BREAK',d:'Quebrar defesa'},
    
    // SKINS E COSMÉTICA (5 letras)
    {w:'SPECTRUM',d:'Skin colorida'}, // 8 letras - skip
    {w:'PIXEL',d:'Skin pixelada'}, // 5 letras!
    {w:'GLOSS',d:'Acabamento brilhante'},
    {w:'SLATE',d:'Skin cinzenta'},
    {w:'PRISM',d:'Skin prisma'},
    
    // ECONOMIA DE JOGO (5 letras)
    {w:'PISTOL',d:'Rodada inicial'}, // 6 letras - skip
    {w:'ECO',d:'Economia jogo'}, // 3 letras - skip
    {w:'ECON',d:'Economia da rodada'}, // 4 letras - skip
    {w:'CREDIT',d:'Dinheiro jogo'}, // 6 letras - skip
    {w:'BONUS',d:'Ganho extra rodada'},
    {w:'LOSS',d:'Derrota rodada'}, // 4 letras - skip
    
    // ADVERSÁRIOS (5 letras)
    {w:'ENEMY',d:'Inimigo adversário'},
    {w:'SQUAD',d:'Equipe companheiros'},
    {w:'TEAM',d:'Time jogar'}, // 4 letras - skip
    
    // TÁTICA E ESTRATÉGIA (5 letras)
    {w:'ANGLE',d:'Ângulo de ataque'},
    {w:'FLANK',d:'Ataque pelas costas'}, // 5 letras!
    {w:'RUSH',d:'Ataque rápido'}, // 4 letras - skip
    {w:'STALL',d:'Atrasar tempo'},
    {w:'PIVOT',d:'Mudança de estratégia'},
    {w:'SCOUT',d:'Reconhecimento área'},
    {w:'TRACK',d:'Rastrear inimigo'},
    {w:'BAIT',d:'Isca para inimigo'}, // 4 letras - skip
  ];
  
  // Filter only 5-letter words
  const WORDS_5 = WORDS.filter(item => item.w.length === 5);

  const WORD_LENGTH = 5;
  const MAX_GUESSES = 6;

  let answer, answerDesc, guesses, currentGuess, gameOver, keyStates, currentRow;
  let stats = { wins: 0, losses: 0 };

  function pickWord() {
    const pick = WORDS_5[Math.floor(Math.random() * WORDS_5.length)];
    return pick;
  }

  function newGame() {
    document.getElementById('modal').style.display = 'none';
    const pick = pickWord();
    answer = pick.w;
    answerDesc = pick.d;
    guesses = [];
    currentGuess = '';
    currentRow = 0;
    gameOver = false;
    keyStates = {};
    buildGrid();
    buildKeyboard();
  }

  function buildGrid() {
    const grid = document.getElementById('grid');
    grid.innerHTML = '';
    for (let r = 0; r < MAX_GUESSES; r++) {
      const row = document.createElement('div');
      row.className = 'flex gap-1.5';
      row.id = 'row-' + r;
      for (let c = 0; c < answer.length; c++) {
        const cell = document.createElement('div');
        cell.className = 'cell';
        cell.id = `cell-${r}-${c}`;
        row.appendChild(cell);
      }
      grid.appendChild(row);
    }
  }

  const ROWS = [
    ['Q','W','E','R','T','Y','U','I','O','P'],
    ['A','S','D','F','G','H','J','K','L'],
    ['ENTER','Z','X','C','V','B','N','M','⌫']
  ];

  function buildKeyboard() {
    const kb = document.getElementById('keyboard');
    kb.innerHTML = '';
    ROWS.forEach(row => {
      const r = document.createElement('div');
      r.className = 'flex gap-1 justify-center';
      row.forEach(k => {
        const btn = document.createElement('button');
        btn.className = 'key' + (k === 'ENTER' || k === '⌫' ? ' wide' : '');
        btn.textContent = k;
        btn.id = 'key-' + k;
        btn.addEventListener('click', () => handleKey(k));
        r.appendChild(btn);
      });
      kb.appendChild(r);
    });
  }

  function handleKey(k) {
    if (gameOver) return;
    if (k === '⌫') {
      currentGuess = currentGuess.slice(0, -1);
      updateRow();
    } else if (k === 'ENTER') {
      submitGuess();
    } else if (currentGuess.length < answer.length) {
      currentGuess += k;
      updateRow();
      const cell = document.getElementById(`cell-${currentRow}-${currentGuess.length - 1}`);
      if (cell) cell.classList.add('pop-in');
    }
  }

  function updateRow() {
    for (let c = 0; c < answer.length; c++) {
      const cell = document.getElementById(`cell-${currentRow}-${c}`);
      cell.textContent = currentGuess[c] || '';
      cell.classList.toggle('active', c === currentGuess.length && !gameOver);
    }
  }

  function showToast(msg, color = '#ff4655') {
    const cont = document.getElementById('toast-container');
    const t = document.createElement('div');
    t.className = 'toast-msg';
    t.style.background = color;
    t.textContent = msg;
    cont.appendChild(t);
    setTimeout(() => t.remove(), 1800);
  }

  function submitGuess() {
    if (currentGuess.length !== answer.length) {
      document.getElementById('row-' + currentRow).classList.add('shake');
      setTimeout(() => document.getElementById('row-' + currentRow).classList.remove('shake'), 500);
      showToast(`Precisa ter ${answer.length} letras!`);
      return;
    }

    const guess = currentGuess.toUpperCase();
    guesses.push(guess);

    // Evaluate
    const result = evaluate(guess, answer);
    revealRow(currentRow, guess, result, () => {
      // Update keyboard
      result.forEach((state, i) => {
        const letter = guess[i];
        const prev = keyStates[letter];
        if (state === 'correct' || (!prev && state !== 'correct') || prev === 'absent') {
          if (state === 'correct' || (prev !== 'correct')) keyStates[letter] = state;
        }
        const keyEl = document.getElementById('key-' + letter);
        if (keyEl) {
          if (keyStates[letter] === 'correct') keyEl.className = 'key correct';
          else if (keyStates[letter] === 'present') keyEl.className = 'key present';
          else if (keyStates[letter] === 'absent') keyEl.className = 'key absent';
        }
      });

      if (guess === answer) {
        gameOver = true;
        setTimeout(() => showModal(true), 400);
      } else if (guesses.length >= MAX_GUESSES) {
        gameOver = true;
        setTimeout(() => showModal(false), 400);
      } else {
        currentRow++;
        currentGuess = '';
      }
    });
  }

  function evaluate(guess, ans) {
    const result = Array(ans.length).fill('absent');
    const ansArr = ans.split('');
    const used = Array(ans.length).fill(false);

    // Correct first
    for (let i = 0; i < ans.length; i++) {
      if (guess[i] === ansArr[i]) {
        result[i] = 'correct';
        used[i] = true;
      }
    }
    // Present
    for (let i = 0; i < ans.length; i++) {
      if (result[i] === 'correct') continue;
      for (let j = 0; j < ans.length; j++) {
        if (!used[j] && guess[i] === ansArr[j]) {
          result[i] = 'present';
          used[j] = true;
          break;
        }
      }
    }
    return result;
  }

  function revealRow(row, guess, result, cb) {
    let i = 0;
    function next() {
      if (i >= guess.length) { cb(); return; }
      const cell = document.getElementById(`cell-${row}-${i}`);
      cell.classList.add('flip-in', result[i]);
      cell.classList.remove('active');
      i++;
      setTimeout(next, 150);
    }
    next();
  }

  function showModal(won) {
    const m = document.getElementById('modal');
    document.getElementById('modal-icon').textContent = won ? '🏆' : '💀';
    document.getElementById('modal-title').textContent = won ? 'VITÓRIA!' : 'DERROTA';
    document.getElementById('modal-word').textContent = `A palavra era: ${answer}`;
    document.getElementById('modal-desc').textContent = answerDesc;
    m.style.display = 'flex';
    
    if (won) {
      stats.wins++;
      createConfetti();
      
      // Efeito na grid
      document.querySelectorAll(`#row-${currentRow} .cell`).forEach((cell, i) => {
        setTimeout(() => {
          cell.classList.add('victory-pulse');
        }, i * 100);
      });
      
      // Efeito no modal
      setTimeout(() => {
        const modal = m.querySelector('[style*="background"]');
        if (modal) modal.classList.add('victory-pulse');
      }, 600);
    } else {
      stats.losses++;
    }
    document.getElementById('win-count').textContent = stats.wins;
    document.getElementById('loss-count').textContent = stats.losses;
    
    localStorage.setItem('valorant-stats', JSON.stringify(stats));
  }

  function createConfetti() {
    const colors = ['#ff4655', '#538d4e', '#b59f3b', '#6366f1', '#ec4899'];
    const confettiCount = 30;
    
    for (let i = 0; i < confettiCount; i++) {
      const confetti = document.createElement('div');
      confetti.style.position = 'fixed';
      confetti.style.left = Math.random() * 100 + '%';
      confetti.style.top = '-10px';
      confetti.style.width = '8px';
      confetti.style.height = '8px';
      confetti.style.background = colors[Math.floor(Math.random() * colors.length)];
      confetti.style.borderRadius = '50%';
      confetti.style.zIndex = '300';
      confetti.style.pointerEvents = 'none';
      confetti.classList.add('confetti-piece');
      confetti.style.animationDelay = (i * 0.05) + 's';
      document.body.appendChild(confetti);
      
      setTimeout(() => confetti.remove(), 1500);
    }
  }

  // Keyboard input
  document.addEventListener('keydown', (e) => {
    if (e.ctrlKey || e.metaKey || e.altKey) return;
    if (e.key === 'Enter') handleKey('ENTER');
    else if (e.key === 'Backspace') handleKey('⌫');
    else if (/^[a-zA-Z]$/.test(e.key)) handleKey(e.key.toUpperCase());
  });

  // === Element SDK ===
  const defaultConfig = {
    game_title: 'VALORANT',
    background_color: '#0f1923',
    accent_color: '#ff4655',
    text_color: '#ffffff',
    surface_color: '#1a1a2e',
    font_family: 'Orbitron'
  };

  function applyConfig(config) {
    const t = config.game_title || defaultConfig.game_title;
    document.getElementById('title').textContent = t;

    const bg = config.background_color || defaultConfig.background_color;
    const accent = config.accent_color || defaultConfig.accent_color;
    const txt = config.text_color || defaultConfig.text_color;
    const surface = config.surface_color || defaultConfig.surface_color;
    const font = config.font_family || defaultConfig.font_family;

    const app = document.getElementById('app');
    app.style.background = `linear-gradient(135deg, ${bg} 0%, ${surface} 50%, ${bg} 100%)`;

    document.getElementById('title').style.color = accent;
    document.getElementById('title').style.fontFamily = `${font}, monospace`;

    document.querySelectorAll('.cell').forEach(c => { c.style.color = txt; c.style.fontFamily = `${font}, monospace`; });
    document.getElementById('modal-btn').style.background = accent;
    document.getElementById('modal-title').style.color = accent;
  }

  if (window.elementSdk) {
    window.elementSdk.init({
      defaultConfig,
      onConfigChange: async (config) => applyConfig(config),
      mapToCapabilities: (config) => ({
        recolorables: [
          { get: () => config.background_color || defaultConfig.background_color, set: (v) => { config.background_color = v; window.elementSdk.setConfig({ background_color: v }); } },
          { get: () => config.surface_color || defaultConfig.surface_color, set: (v) => { config.surface_color = v; window.elementSdk.setConfig({ surface_color: v }); } },
          { get: () => config.text_color || defaultConfig.text_color, set: (v) => { config.text_color = v; window.elementSdk.setConfig({ text_color: v }); } },
          { get: () => config.accent_color || defaultConfig.accent_color, set: (v) => { config.accent_color = v; window.elementSdk.setConfig({ accent_color: v }); } }
        ],
        borderables: [],
        fontEditable: { get: () => config.font_family || defaultConfig.font_family, set: (v) => { config.font_family = v; window.elementSdk.setConfig({ font_family: v }); } },
        fontSizeable: undefined
      }),
      mapToEditPanelValues: (config) => new Map([
        ['game_title', config.game_title || defaultConfig.game_title]
      ])
    });
  }

  newGame();
  lucide.createIcons();
  
  // Load stats from localStorage
  const saved = localStorage.getItem('valorant-stats');
  if (saved) {
    stats = JSON.parse(saved);
    document.getElementById('win-count').textContent = stats.wins;
    document.getElementById('loss-count').textContent = stats.losses;
